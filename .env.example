# RustAssist bot
RPP_DISCORD_USERNAME=RustAssist
RPP_DISCORD_CLIENT_ID=YOUR_DISCORD_APPLICATION_CLIENT_ID
RPP_DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
RPP_NEED_ADMIN_PRIVILEGES=true

# General bot settings
RPP_LANGUAGE=en
RPP_POLLING_INTERVAL=10000
RPP_RECONNECT_INTERVAL=15000
RPP_LOG_CALL_STACK=false
RPP_BATTLEMETRICS_TOKEN=

# License/fleet client used by the Discord bot
RPP_LICENSE_REQUIRED=true
RPP_LICENSE_API_URL=http://localhost:8000
RPP_LICENSE_VALIDATION_GRACE_MS=86400000
RPP_LICENSE_ACTIVATION_TIMEOUT_MS=900000
RPP_LICENSE_BYPASS=false
RPP_BOT_INSTANCE_ID=rustassist-1
RPP_BOT_INSTANCE_TOKEN=CHANGE_ME_INSTANCE_TOKEN
RPP_BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=YOUR_DISCORD_APPLICATION_CLIENT_ID
RPP_BOT_ACTIVE_GUILD_LIMIT=20

# Stream Deck bridge
RPP_STREAM_DECK_ENABLED=false
RPP_STREAM_DECK_HOST=localhost
RPP_STREAM_DECK_PORT=8074
RPP_STREAM_DECK_API_PASSWORDS=

# Central license API
LICENSE_API_DATABASE_URL=sqlite:///./license_api.sqlite
LICENSE_API_ADMIN_TOKEN=CHANGE_ME_ADMIN_TOKEN
LICENSE_API_BOOTSTRAP_INSTANCE_ID=rustassist-1
LICENSE_API_BOOTSTRAP_INSTANCE_TOKEN=CHANGE_ME_INSTANCE_TOKEN
LICENSE_API_BOOTSTRAP_INVITE_URL=https://discord.com/oauth2/authorize?client_id=YOUR_DISCORD_APPLICATION_CLIENT_ID&permissions=8&scope=bot%20applications.commands
LICENSE_API_BOOTSTRAP_ACTIVE_GUILD_LIMIT=20
LICENSE_API_HOST=127.0.0.1
LICENSE_API_PORT=8000
LICENSE_API_RELOAD=false
